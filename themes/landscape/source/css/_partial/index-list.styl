// Home page article list — modern card style
// Applied only when partial('article') is rendered with index: true.

.article
  position: relative
  margin: 0 0 24px
  transition: transform 0.25s ease

  // Card visual
  .article-inner
    border-radius: 8px
    border: 1px solid color-border
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04)
    background: #fff
    transition: box-shadow 0.25s ease, border-color 0.25s ease, transform 0.25s ease
    overflow: hidden
    position: relative
    padding: 4px 0 4px

    // Left accent bar (revealed on hover)
    &:before
      content: ""
      position: absolute
      left: 0
      top: 0
      bottom: 0
      width: 4px
      background: linear-gradient(180deg, color-link, lighten(color-link, 15%))
      transform: scaleY(0)
      transform-origin: top center
      transition: transform 0.25s ease

  &:hover
    .article-inner
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08)
      border-color: lighten(color-link, 30%)
      transform: translateY(-2px)
      &:before
        transform: scaleY(1)
    .article-title a
      color: color-link

  // Meta row (date + category) — slim, muted, all on one line
  .article-meta
    display: flex
    flex-wrap: wrap
    align-items: center
    gap: 10px
    padding: 16px article-padding 0
    font-size: 0.8em
    color: color-grey
    line-height: 1

    .article-date
      margin: 0
      float: none
      color: color-grey
      letter-spacing: 0.4px
      &:before
        content: "\f017"
        font-family: ForkAwesome
        margin-right: 6px
        opacity: 0.5

    .article-category
      float: none
      margin: 0
      color: inherit
      text-shadow: none
      &:before
        content: ""
      .article-category-link
        display: inline-block
        margin: 0
        padding: 3px 10px
        border-radius: 12px
        background: alpha(color-link, 0.08)
        color: color-link
        font-size: 0.95em
        line-height: 1.4
        text-transform: lowercase
        letter-spacing: 0.5px
        transition: background 0.2s ease, color 0.2s ease
        &:hover
          background: color-link
          color: #fff

  .article-header
    padding: 8px article-padding 0

  .article-title
    margin: 0
    font-size: 1.45em
    line-height: 1.4
    font-weight: 600
    letter-spacing: -0.2px
    a
      color: color-default
      text-decoration: none
      transition: color 0.2s ease

// Auto-generated excerpt block on the index list
.article-excerpt
  padding: 8px article-padding 16px
  color: lighten(color-default, 18%)
  font-size: 0.95em
  line-height: 1.75
  p
    margin: 0
  // Don't pull big media into the card; keep heights consistent
  img, video, iframe, table, pre
    display: none

.article-list-footer
  padding: 0 article-padding 16px
  display: flex
  flex-wrap: wrap
  align-items: center
  justify-content: flex-end
  gap: 10px
  font-size: 0.82em
  color: color-grey


  .article-more-link-btn
    display: inline-block
    padding: 5px 14px
    border-radius: 16px
    background: color-background
    color: color-grey
    text-decoration: none
    font-weight: 500
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease
    &:hover
      background: color-link
      color: #fff
      transform: translateX(2px)

@media mq-mobile
  .article
    margin-bottom: 16px
    .article-title
      font-size: 1.2em
    .article-excerpt
      font-size: 0.9em
      line-height: 1.65
    .article-list-footer
      font-size: 0.78em

