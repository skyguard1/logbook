S// Home page article list — card style
// Applied only when partial('article') is rendered with index: true.
// We scope by `.article` containers that DO NOT have the entry/content body.

.article
  position: relative
  transition: transform 0.2s ease, box-shadow 0.2s ease

  // Card visual
  .article-inner
    border-radius: 6px
    border: 1px solid color-border
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04)
    background: #fff
    transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease
    overflow: hidden
    position: relative

    // Left accent bar
    &:before
      content: ""
      position: absolute
      left: 0
      top: 0
      bottom: 0
      width: 3px
      background: color-link
      opacity: 0
      transition: opacity 0.2s ease

  &:hover
    .article-inner
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08)
      border-color: darken(color-border, 8%)
      transform: translateY(-2px)
      &:before
        opacity: 1
    .article-title a
      color: color-link

  // Tighter, lighter meta on list view
  .article-meta
    padding: 14px article-padding 0
    font-size: 0.78em
    color: color-grey
    .article-date
      margin: 0
      color: color-grey
      letter-spacing: 0.5px
    .article-category
      text-shadow: none
      color: #ccc

  .article-header
    padding: 6px article-padding 0

  .article-title
    font-size: 1.5em
    line-height: 1.35
    a
      color: color-default
      text-decoration: none

// Excerpt block on the index list
.article-excerpt
  padding: 6px article-padding 18px
  color: lighten(color-default, 15%)
  font-size: 0.95em
  line-height: 1.7
  p
    margin: 0.4em 0
  // Hide huge images from excerpt so cards keep consistent height
  img, video, iframe, table, pre
    display: none
  .article-more-link
    margin: 12px 0 0
    a
      display: inline-block
      padding: 4px 12px
      border-radius: 14px
      background: color-background
      color: color-grey
      font-size: 0.85em
      text-decoration: none
      transition: background 0.2s ease, color 0.2s ease
      &:hover
        background: color-link
        color: #fff

@media mq-mobile
  .article
    .article-title
      font-size: 1.25em
    .article-excerpt
      font-size: 0.9em

