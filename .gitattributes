# Normalize line endings on commit. Avoids the
# "CRLF will be replaced by LF" warning on macOS/Linux clones.
* text=auto eol=lf

# Binary assets — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

